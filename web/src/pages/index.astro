---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { disclosure } from '../lib/disclosure';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.published_at.valueOf() - a.data.published_at.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const reactionStamps = ['OMG', 'LOL', 'SHOCKING'];
---

<BaseLayout description="Celebrity gossip, every claim hash-locked. TMZ meets the blockchain.">
  <div class="page-grid">
    <section class="feed-col">

      <!-- Mobile-first widget (visible only ≤820px when sidebar hides) -->
      <div class="mobile-first-widget">
        <div class="side-box">
          <h3 class="tab-label">HOT OR NOT</h3>
          <div class="side-poll" id="poll-mobile">
            <div class="poll-item"><span class="poll-celeb">KANYE WEST</span><div class="poll-bars"><button class="poll-btn" data-vote="kanye-hot">🔥 HOT</button><button class="poll-btn" data-vote="kanye-not">🗑️ NOT</button></div></div>
            <div class="poll-item"><span class="poll-celeb">TAYLOR SWIFT</span><div class="poll-bars"><button class="poll-btn" data-vote="taylor-hot">🔥 HOT</button><button class="poll-btn" data-vote="taylor-not">🗑️ NOT</button></div></div>
            <div class="poll-item"><span class="poll-celeb">KIM KARDASHIAN</span><div class="poll-bars"><button class="poll-btn" data-vote="kim-hot">🔥 HOT</button><button class="poll-btn" data-vote="kim-not">🗑️ NOT</button></div></div>
          </div>
        </div>
      </div>

      <div class="feed-header">
        <h1>LATEST</h1>
        <span class="feed-count">{articles.length} STORIES</span>
      </div>

      {
        articles.length === 0 ? (
          <p class="empty">No stories yet. The newsroom is scouring the tabloids.</p>
        ) : (
          <ul class="feed">
            {articles.map((article, i) => {
              const d = disclosure(article.data.review_path, article.data.label);
              const receiptCount = article.data.claim_evidence.length;
              const heatBlocks = Math.min(5, Math.ceil(receiptCount / 2));
              return (
                <li>
                  <a class="card" href={`/articles/${article.id}`}>
                    {i === 0 && <span class="starburst" aria-hidden="true"><span>EXCLUSIVE</span></span>}
                    {i === 0 && <span class="flag flag--lead">LEAD STORY</span>}
                    {i === 0 && <span class="flag flag--new">NEW</span>}
                    {i >= 1 && <span class="card-rank" aria-hidden="true">#{i + 1}</span>}
                    {i >= 1 && <span class="react-stamp" aria-hidden="true">{reactionStamps[i % 3]}</span>}
                    <div class="card-rail">
                      <span class={`badge badge--${d.cls}`}>{d.text}</span>
                      <time datetime={article.data.published_at.toISOString()}>
                        {dateFmt.format(article.data.published_at)}
                      </time>
                    </div>
                    <h2>{article.data.headline}</h2>
                    {article.data.dek && <p class="dek">{article.data.dek}</p>}
                    <div class="card-foot">
                      <div class="card-foot-left">
                        <span class="receipts">🧾 {receiptCount} RECEIPTS</span>
                        <span class="type-tag">{article.data.type.replace(/_/g, ' ')}</span>
                      </div>
                      <div class="heat" aria-label={`Scandal heat: ${heatBlocks} of 5`}>
                        {Array.from({ length: 5 }).map((_, j) => (
                          <span class={`heat-block${j < heatBlocks ? ' heat-block--on' : ''}`} aria-hidden="true">🔥</span>
                        ))}
                      </div>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }

      <!-- Paparazzi photo grid -->
      <section class="papwall">
        <h2 class="tab-label">CAUGHT ON CAMERA</h2>
        <div class="pap-grid">
          <figure><img src="https://placehold.co/400x400/222/FFE600?text=SPOTTED" alt="Paparazzi photo: Celebrity spotted out" loading="lazy" width="400" height="400"><figcaption>SPOTTED: 3AM TACO RUN</figcaption></figure>
          <figure><img src="https://placehold.co/400x400/222/FF2D95?text=BUSTED" alt="Paparazzi photo: Celebrity caught" loading="lazy" width="400" height="400"><figcaption>BUSTED: NO RING?!</figcaption></figure>
          <figure><img src="https://placehold.co/400x400/222/00C2FF?text=EXCLUSIVE" alt="Paparazzi photo: Exclusive sighting" loading="lazy" width="400" height="400"><figcaption>EXCLUSIVE: WHO'S THAT?</figcaption></figure>
          <figure><img src="https://placehold.co/400x400/222/B6FF00?text=YIKES" alt="Paparazzi photo: Outfit disaster" loading="lazy" width="400" height="400"><figcaption>YIKES: OUTFIT FAIL</figcaption></figure>
          <figure><img src="https://placehold.co/400x400/222/FFE600?text=SHOCK" alt="Paparazzi photo: Shocking incident" loading="lazy" width="400" height="400"><figcaption>SHOCK SPLIT?</figcaption></figure>
          <figure><img src="https://placehold.co/400x400/222/FF0033?text=LEAKED" alt="Paparazzi photo: Leaked documents" loading="lazy" width="400" height="400"><figcaption>LEAKED DMs</figcaption></figure>
        </div>
      </section>
    </section>

    <aside class="side-col">
      <div class="side-box">
        <h3 class="tab-label">ABOUT</h3>
        <p>Machine-written gossip. Every claim hash-locked to its source span. Don't trust us — verify the receipts.</p>
      </div>

      <div class="side-box">
        <h3 class="tab-label">SCANDAL-O-METER</h3>
        <p class="meter-label">TODAY'S DRAMA LEVEL: CRITICAL</p>
        <div class="meter-bars" aria-label="Drama level: 4 of 5">
          <span class="meter-bar meter-bar--on"></span>
          <span class="meter-bar meter-bar--on"></span>
          <span class="meter-bar meter-bar--on"></span>
          <span class="meter-bar meter-bar--on"></span>
          <span class="meter-bar"></span>
        </div>
      </div>

      <div class="side-box">
        <h3 class="tab-label">HOT OR NOT</h3>
        <div class="side-poll" id="poll-sidebar">
          <div class="poll-item"><span class="poll-celeb">KANYE WEST</span><div class="poll-bars"><button class="poll-btn" data-vote="kanye-hot">🔥</button><button class="poll-btn" data-vote="kanye-not">🗑️</button></div></div>
          <div class="poll-item"><span class="poll-celeb">TAYLOR SWIFT</span><div class="poll-bars"><button class="poll-btn" data-vote="taylor-hot">🔥</button><button class="poll-btn" data-vote="taylor-not">🗑️</button></div></div>
          <div class="poll-item"><span class="poll-celeb">KIM KARDASHIAN</span><div class="poll-bars"><button class="poll-btn" data-vote="kim-hot">🔥</button><button class="poll-btn" data-vote="kim-not">🗑️</button></div></div>
        </div>
      </div>

      <div class="side-box">
        <h3 class="tab-label">BLIND ITEM</h3>
        <p class="blind-tease">WHICH A-LIST COUPLE IS HEADED FOR A $200M DIVORCE? Insiders say the papers are already drafted. The prenup is... complicated. <em>Names coming when the ink dries.</em></p>
      </div>

      <div class="side-box">
        <h3 class="tab-label">DON'T MISS</h3>
        <ul class="trending-list">
          {articles.map(a => (
            <li><a href={`/articles/${a.id}`}>{a.data.headline}</a></li>
          ))}
        </ul>
      </div>

      <div class="side-box">
        <h3 class="tab-label">MOST READ</h3>
        <ol class="trending-list trending-list--numbered">
          {articles.map(a => (
            <li><a href={`/articles/${a.id}`}>{a.data.headline}</a></li>
          ))}
        </ol>
      </div>

      <div class="side-box">
        <h3 class="tab-label">TAGS</h3>
        <div class="tag-cloud">
          <span class="tag">kanye-west</span>
          <span class="tag">san-antonio</span>
          <span class="tag">concert-cancellation</span>
          <span class="tag">july-4</span>
          <span class="tag">casting-news</span>
          <span class="tag">sightings</span>
          <span class="tag">blind-items</span>
          <span class="tag">box-office</span>
          <span class="tag">breakups</span>
          <span class="tag">legal-drama</span>
        </div>
      </div>

      <div class="side-box side-box--cta">
        <span class="starburst-cta" aria-hidden="true"><span>TIP US</span></span>
        <h3 class="tab-label" style="background:var(--yell);color:var(--line-dark)">GOT A TIP?</h3>
        <p>We verify everything. Your tip stays anonymous.</p>
        <a href="#subscribe" class="btn-aero">SEND TIP</a>
      </div>
    </aside>
  </div>

  <script>
    // HOT OR NOT localStorage poll (try/catch guarded for Safari private mode)
    function initPoll(id) {
      const poll = document.getElementById(id);
      if (!poll) return;
      poll.querySelectorAll('.poll-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const key = btn.dataset.vote;
          try {
            const current = parseInt(localStorage.getItem(key) || '0');
            localStorage.setItem(key, String(current + 1));
          } catch (_) { /* storage blocked — button still works visually */ }
          btn.classList.add('voted');
          setTimeout(() => btn.classList.remove('voted'), 600);
        });
      });
    }
    initPoll('poll-sidebar');
    initPoll('poll-mobile');
  </script>

  <style>
    .page-grid {
      display: grid;
      grid-template-columns: 1fr 260px;
      gap: 32px;
      align-items: start;
    }

    .mobile-first-widget { display: none; }

    /* ── Feed column ── */
    .feed-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-bottom: var(--rule) solid var(--line-dark);
      padding-bottom: 10px;
      margin-bottom: 16px;
    }
    .feed-header h1 {
      font-size: 26px;
      font-weight: 900;
      letter-spacing: -0.02em;
      margin: 0;
      font-family: var(--display);
      text-transform: uppercase;
    }
    .feed-count {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ink-faint);
    }
    .empty {
      color: var(--ink-faint);
      font-style: italic;
      padding: 32px 0;
    }

    .feed {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 14px;
    }

    /* ── Card ── */
    .card {
      display: block;
      background: var(--surface);
      backdrop-filter: blur(var(--blur));
      -webkit-backdrop-filter: blur(var(--blur));
      border: var(--rule-mid) solid var(--line-dark);
      padding: 18px 20px;
      color: var(--ink);
      position: relative;
      transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
      box-shadow: var(--shadow-hard);
      overflow: hidden;
    }
    .card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gloss);
      pointer-events: none;
      z-index: 1;
    }
    .card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 0, rgba(255,255,255,0.9), transparent 60%);
      opacity: 0;
      pointer-events: none;
      z-index: 3;
    }
    .card:hover {
      text-decoration: none;
      border-color: var(--red);
      transform: translate(-2px, -2px);
      box-shadow: 8px 8px 0 var(--red);
    }
    .card:hover::after {
      animation: flash .4s ease-out;
    }
    .card:focus-visible {
      outline: 3px solid var(--red);
      outline-offset: 2px;
    }

    /* Flags */
    .flag {
      display: inline-block;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 4px 10px;
      margin-bottom: 10px;
      position: relative;
      z-index: 2;
    }
    .flag--lead {
      background: var(--line-dark);
      color: #FFF;
      margin-right: 6px;
    }
    .flag--new {
      background: var(--red);
      color: #FFF;
      transform: rotate(-4deg);
      box-shadow: var(--shadow-glow);
    }

    /* Card rank #N (items 2+) */
    .card-rank {
      position: absolute;
      top: 6px;
      right: 10px;
      font-family: var(--display);
      font-size: 38px;
      font-weight: 900;
      color: transparent;
      -webkit-text-stroke: 2px var(--line);
      line-height: 1;
      z-index: 0;
    }

    /* Reaction stamps (LOL/OMG/SHOCKING) */
    .react-stamp {
      position: absolute;
      bottom: 14px;
      right: 10px;
      font-family: var(--display);
      font-size: 20px;
      font-weight: 900;
      color: var(--magenta);
      transform: rotate(-6deg);
      opacity: 0.35;
      z-index: 2;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      pointer-events: none;
    }

    .card-rail {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
      position: relative;
      z-index: 2;
    }
    .card-rail time {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--ink-faint);
      font-variant-numeric: tabular-nums;
    }

    .card h2 {
      font-size: 22px;
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0 0 8px;
      font-family: var(--display);
      text-transform: uppercase;
      position: relative;
      z-index: 2;
    }
    .card:first-child h2 {
      font-size: clamp(28px, 4vw, 38px);
      line-height: 1.15;
    }
    .dek {
      color: var(--ink-soft);
      margin: 0 0 14px;
      font-size: 14.5px;
      line-height: 1.45;
      position: relative;
      z-index: 2;
    }

    .card-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 2px solid var(--line);
      padding-top: 10px;
      position: relative;
      z-index: 2;
    }
    .card-foot-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .receipts {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 700;
      color: var(--red);
    }
    .type-tag {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--ink-faint);
      border: 1px solid var(--line);
      padding: 3px 7px;
    }

    /* Heat meter */
    .heat {
      display: flex;
      gap: 2px;
      font-size: 12px;
    }
    .heat-block {
      opacity: 0.2;
      transition: opacity 0.2s;
    }
    .heat-block--on {
      opacity: 1;
    }

    /* EXCLUSIVE starburst on lead card */
    .card .starburst {
      top: -12px;
      right: -8px;
      width: 80px;
      height: 80px;
      z-index: 5;
    }
    .card .starburst::before,
    .card .starburst::after {
      border-width: 2px;
    }
    .card .starburst span {
      font-size: 10px;
    }

    /* ── Paparazzi grid ── */
    .papwall {
      margin-top: 36px;
      padding-top: 24px;
      border-top: var(--rule) solid var(--line-dark);
    }
    .papwall .tab-label {
      margin-bottom: 14px;
    }
    .pap-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    .pap-grid figure {
      position: relative;
      margin: 0;
      border: 5px solid var(--yell);
      box-shadow: var(--shadow-hard);
      background: #000;
    }
    .pap-grid img {
      display: block;
      width: 100%;
      height: auto;
    }
    .pap-grid figcaption {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0,0,0,.78);
      color: #fff;
      font: 800 11px/1.1 var(--font);
      text-transform: uppercase;
      padding: 5px 7px;
    }

    /* ── Sidebar ── */
    .side-col {
      display: grid;
      gap: 16px;
      position: sticky;
      top: 110px;
    }
    .side-box {
      background: var(--surface);
      backdrop-filter: blur(var(--blur));
      -webkit-backdrop-filter: blur(var(--blur));
      border: var(--rule-mid) solid var(--line-dark);
      padding: 16px;
      box-shadow: var(--shadow-hard);
      position: relative;
    }
    .side-box h3 {
      margin: 0 0 10px;
    }
    .side-box p {
      font-size: 13px;
      color: var(--ink-soft);
      margin: 0;
      line-height: 1.5;
    }

    /* SCANDAL-O-METER */
    .meter-label {
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin: 0 0 8px !important;
      color: var(--ink) !important;
    }
    .meter-bars {
      display: flex;
      gap: 4px;
    }
    .meter-bar {
      flex: 1;
      height: 18px;
      background: var(--line);
      border: 2px solid var(--line-dark);
      transition: background 0.2s;
    }
    .meter-bar--on {
      background: var(--red);
    }

    /* HOT OR NOT poll */
    .poll-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 6px 0;
      border-bottom: 1px solid var(--line);
    }
    .poll-item:last-child { border-bottom: none; }
    .poll-celeb {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .poll-bars {
      display: flex;
      gap: 3px;
    }
    .poll-btn {
      font-size: 13px;
      padding: 3px 7px;
      border: 2px solid var(--line-dark);
      background: #fff;
      cursor: pointer;
      transition: transform 0.1s, background 0.1s;
      line-height: 1.2;
    }
    .poll-btn:hover {
      background: var(--yell);
      transform: translate(-1px, -1px);
    }
    .poll-btn.voted {
      background: var(--red);
      color: #fff;
    }

    /* BLIND ITEM teaser */
    .blind-tease {
      font-size: 13px;
      line-height: 1.5;
      color: var(--ink-soft);
      font-style: italic;
    }
    .blind-tease em {
      color: var(--ink-faint);
      font-size: 11px;
    }

    /* DON'T MISS / MOST READ */
    .trending-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 6px;
    }
    .trending-list--numbered {
      list-style: decimal;
      padding-left: 18px;
    }
    .trending-list li {
      font-size: 13px;
      font-weight: 600;
      line-height: 1.3;
    }
    .trending-list a {
      color: var(--ink);
      display: inline;
    }
    .trending-list a:hover {
      color: var(--red);
      text-decoration: underline;
    }

    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }
    .tag {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--ink);
      background: linear-gradient(135deg, rgba(0,194,255,0.2), rgba(255,255,255,0.6));
      border: 2px solid var(--line-dark);
      padding: 4px 8px;
      transition: background 0.12s;
    }
    .tag:hover { background: var(--yell); border-color: var(--line-dark); }

    .side-box--cta {
      background: var(--line-dark);
      border-color: var(--line-dark);
      color: #FFF;
    }
    .side-box--cta p { color: rgba(255,255,255,0.7); }
    .side-box--cta .btn-aero {
      margin-top: 12px;
    }

    .starburst-cta {
      position: absolute;
      top: -10px;
      left: -8px;
      width: 60px;
      height: 60px;
      display: grid;
      place-items: center;
      z-index: 4;
    }
    .starburst-cta::before,
    .starburst-cta::after {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--yell);
      border: 2px solid var(--line-dark);
    }
    .starburst-cta::before { transform: rotate(0deg); }
    .starburst-cta::after { transform: rotate(45deg); }
    .starburst-cta span {
      position: relative;
      z-index: 1;
      color: var(--line-dark);
      font: 900 9px/1 var(--display);
      transform: rotate(-8deg);
      text-align: center;
      text-transform: uppercase;
    }

    @media (max-width: 820px) {
      .page-grid {
        grid-template-columns: 1fr;
      }
      .mobile-first-widget {
        display: block;
        margin: 0 0 18px;
      }
      .side-col { display: none; }
      .card:first-child h2 { font-size: 22px; }
      .pap-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 480px) {
      .card-rank {
        font-size: 26px;
        top: 4px;
        right: 6px;
      }
      .react-stamp {
        font-size: 15px;
        bottom: 10px;
        right: 6px;
      }
    }
  </style>
</BaseLayout>
